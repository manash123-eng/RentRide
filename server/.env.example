# Server env example for RentRide

# === Mongo ===
MONGO_URI=

# === JWT ===
JWT_SECRET=

# === Client URL for CORS ===
CLIENT_URL=http://localhost:5173

# === Email (Nodemailer) ===
# Required for automatic receipt email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
# optional override (send receipts to this email instead of customer.email)
# EMAIL_TO_OVERRIDE=

# === WhatsApp (choose one provider) ===
# TWILIO (recommended if you have it)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio WhatsApp sender number
TWILIO_FROM_WHATSAPP=

# Meta WhatsApp Cloud API (optional)
WHATSAPP_CLOUD_API_URL=
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Optional: choose provider label (code currently auto-detects by env vars)
WHATSAPP_PROVIDER=twilio

